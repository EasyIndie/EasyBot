# EasyBot 环境变量
#
# 将此文件复制为 .env 并填入你的令牌/密钥。
# 设置令牌后对应平台的适配器会自动启用，无需修改 gateway.yaml。
#
# 此文件不受版本控制（.env 已在 .gitignore 中）。
# Shell export / Docker environment 优先于本文件的值。
#
# 独立运行:
#   easybot --init && vim ~/.easybot/.env && easybot --debug
#
# Docker Compose:
#   cp .env.example .env && vim .env && docker compose up -d
#
# 取消 '#' 注释并填入令牌以启用对应平台。

# Telegram Bot Token（从 @BotFather 获取）
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Discord Bot Token
# DISCORD_BOT_TOKEN=your_discord_bot_token

# 飞书/Lark 应用凭据
# FEISHU_APP_ID=cli_xxxxxxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# QQ 机器人凭据（AppId 作为 app_id，AppSecret 作为 token）
# QQ_APP_ID=your_qq_app_id
# QQ_CLIENT_SECRET=your_qq_client_secret

# 个人微信 iLink Bot Token（已废弃，不再使用。启动后会自动扫码登录）
# 此变量已不再读取，保留仅用于向后兼容参考

# PostgreSQL（可选，默认：SQLite）
# DATABASE_URL=postgresql://user:password@localhost:5432/easybot
